# 複製這個檔成 .env 後填入你的值： cp .env.example .env
# .env 內含 token，已被 .gitignore 排除，不會上傳。

# === Telegram（必填）===
TELEGRAM_BOT_TOKEN=請貼上_BotFather_給你的_token
TELEGRAM_CHAT_ID=請填入群組_chat_id（先空著，啟動後在群組用 /id 取得再回填）

# === CareLink 登入 ===
# 不需要在這裡放任何 token。
# CareLink 登入狀態由「python carelink_web.py login」產生的 carelink_state.json 保存
# （含 session cookie），keep 服務會自動沿用並定期刷新。也已被 .gitignore 排除。

# === 血糖門檻 (mg/dL) ===
LOW_THRESHOLD=70
HIGH_THRESHOLD=180

# === 頻率設定 ===
POLL_INTERVAL_SEC=300          # bot 每幾秒讀一次資料（CGM 約每 5 分鐘更新）
SUMMARY_INTERVAL_HOURS=3       # 每幾小時發一次定時摘要
DAY_START_HOUR=7               # 摘要只在這個時段發（避免半夜吵）
DAY_END_HOUR=23
REALERT_MINUTES=30             # 持續超標時，每隔幾分鐘再提醒一次
STALE_MINUTES=30               # 超過幾分鐘沒新資料就警告（可能上傳中斷）
CHART_HOURS=12                 # 趨勢圖顯示最近幾小時

# === Google Sheets（選填，留空就停用）===
GOOGLE_SHEET_ID=
GOOGLE_SA_FILE=service_account.json
